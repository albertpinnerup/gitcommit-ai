{
  "name": "gitcommit-ai",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "commit": "./index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dev": "bun --watch ./index.ts",
    "demo": "bun ./index.ts --demo",
    "dev:demo": "COMMIT_DEMO_DELAY=0 bun --watch ./index.ts --demo"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@opentui/core": "^0.4.2",
    "@opentui/react": "^0.4.2",
    "nanospinner": "^1.2.2",
    "react": "^19.2.7",
    "tinygradient": "^2.0.1"
  }
}
